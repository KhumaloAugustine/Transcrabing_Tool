{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lalela-transcription",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lalela-db",
      "database_id": "f30ef314-f648-45c3-9189-f422ab153695",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "RECORDINGS",
      "bucket_name": "lalela-recordings"
    }
  ],
  "vars": {
    "TRANSCRIPTION_MODEL": "gpt-4o-transcribe-diarize",
    "LLM_MODEL": "gpt-4.1-mini"
  }
}
